# SkiSense Configuration
# Copy this file to .env and adjust values as needed.
# All settings are optional; defaults are used when omitted.

# =============================================================================
# Processing Settings
# =============================================================================

# Debug mode: show detailed logs and warnings.
# Options: true, false
# Default: false
SKISENSE_DEBUG=false

# Show GUI preview window during processing.
# Options: true, false
# Default: false
SKISENSE_SHOW_GUI=false

# Device preference for PyTorch / Ultralytics inference.
# Options: auto, mps, cuda, cpu
#   - auto: Auto-detect (priority: MPS > CUDA > CPU)
#   - mps: Force Apple Silicon GPU
#   - cuda: Force NVIDIA GPU
#   - cpu: Force CPU
# Default: auto
SKISENSE_DEVICE=auto

# =============================================================================
# Detection & Tracking Settings
# =============================================================================

# YOLO person detection confidence threshold.
# Range: 0.0 - 1.0
# Default: 0.3
SKISENSE_YOLO_CONFIDENCE=0.3

# Deep SORT: max frames to keep a track alive without detection.
# Default: 30
SKISENSE_DEEPSORT_MAX_AGE=30

# Deep SORT: frames required to confirm a new track.
# Default: 1
SKISENSE_DEEPSORT_N_INIT=1

# Minimum keypoint confidence for upper-body joints.
# Range: 0.0 - 1.0
# Default: 0.5
SKISENSE_POSE_VISIBILITY_THRESHOLD=0.5

# Minimum keypoint confidence for leg joints (hip, knee, ankle).
# Looser by default because ski postures heavily occlude the inside leg.
# Range: 0.0 - 1.0
# Default: 0.3
SKISENSE_POSE_VISIBILITY_THRESHOLD_LEGS=0.3

# ROI padding ratio: expand the person bbox before pose estimation.
# Range: 0.0 - 1.0 (0.3 = 30% expansion on each side)
# Default: 0.3
SKISENSE_ROI_PADDING=0.3

# Apply CLAHE (adaptive histogram equalization) to the ROI before pose estimation.
# Can help low-contrast footage, but may amplify snow noise. Keep disabled unless
# validated on your data.
# Options: true, false
# Default: false
SKISENSE_CLAHE_ENABLED=false

# Flip Test-Time Augmentation: run pose estimation on the horizontally flipped ROI
# as well, unflip the landmarks, and keep the ones with higher confidence.
# Doubles inference time but can recover landmarks on heavily occluded limbs.
# Options: true, false
# Default: false
SKISENSE_FLIP_TTA_ENABLED=false

# =============================================================================
# Pose Model Settings
# =============================================================================

# YOLO11-Pose model filename.
# Options: yolo11n-pose.pt, yolo11s-pose.pt, yolo11m-pose.pt,
#          yolo11l-pose.pt, yolo11x-pose.pt
# Default: yolo11x-pose.pt
# Note: Ultralytics auto-downloads the weights on first run. SkiSense caches
#       them under models/.
SKISENSE_YOLO_POSE_MODEL=yolo11x-pose.pt

# YOLO11-Pose detection confidence threshold.
# Range: 0.0 - 1.0
# Default: 0.25
SKISENSE_YOLO_POSE_CONFIDENCE=0.25

# =============================================================================
# Zoom Settings
# =============================================================================

# Enable automatic zoom to keep the skier centered.
# Options: true, false
# Default: true
SKISENSE_ZOOM_ENABLED=true

# Zoom magnification level.
# Range: 1.0 - 5.0
# Default: 1.2
SKISENSE_ZOOM_SCALE=1.2

# Zoom smoothing factor (exponential moving average).
# Range: 0.0 - 1.0 (lower = smoother, higher = more responsive)
# Default: 0.08
SKISENSE_ZOOM_SMOOTHING=0.08

# Padding multiplier around bounding box.
# Range: 0.5 - 5.0
# Default: 1.0
SKISENSE_ZOOM_PADDING=1.0

# =============================================================================
# Common Development Configurations
# =============================================================================

# Development mode:
# SKISENSE_DEBUG=true
# SKISENSE_SHOW_GUI=true

# Production mode:
# SKISENSE_DEBUG=false
# SKISENSE_SHOW_GUI=false

# High confidence mode:
# SKISENSE_YOLO_CONFIDENCE=0.5
# SKISENSE_YOLO_POSE_CONFIDENCE=0.4

# CPU-only mode:
# SKISENSE_DEVICE=cpu
