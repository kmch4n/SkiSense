# SkiSense Configuration
# Copy this file to .env and adjust values as needed
# All settings are optional - defaults are used if not specified

# =============================================================================
# Processing Settings
# =============================================================================

# Debug mode: Show detailed logs and warnings
# Options: true, false
# Default: false
SKISENSE_DEBUG=false

# Show GUI preview window during processing
# Options: true, false
# Default: false
SKISENSE_SHOW_GUI=false

# Device preference for PyTorch inference
# Options: auto, mps, cuda, cpu
#   - auto: Auto-detect (priority: MPS > CUDA > CPU)
#   - mps: Force Apple Silicon GPU (macOS M1/M2/M3 only)
#   - cuda: Force NVIDIA GPU (requires CUDA toolkit)
#   - cpu: Force CPU (no GPU acceleration)
# Default: auto
SKISENSE_DEVICE=auto

# =============================================================================
# Detection & Tracking Settings
# =============================================================================

# YOLO person detection confidence threshold
# Range: 0.0 - 1.0 (lower = more detections, higher = fewer false positives)
# Default: 0.3
SKISENSE_YOLO_CONFIDENCE=0.3

# Deep SORT: Max frames to keep track without detection
# Higher values = more persistent tracking through occlusions
# Default: 30
SKISENSE_DEEPSORT_MAX_AGE=30

# Deep SORT: Frames required to confirm new track
# Higher values = fewer false tracks, but slower detection
# Default: 1
SKISENSE_DEEPSORT_N_INIT=1

# MediaPipe pose presence confidence threshold
# Range: 0.0 - 1.0
# Default: 0.3
SKISENSE_POSE_PRESENCE_CONF=0.3

# MediaPipe pose tracking confidence threshold
# Range: 0.0 - 1.0
# Default: 0.3
SKISENSE_POSE_TRACKING_CONF=0.3

# MediaPipe pose detection confidence threshold
# Range: 0.0 - 1.0 (higher = stricter detection, fewer false positives)
# Default: 0.5
SKISENSE_POSE_DETECTION_CONFIDENCE=0.5

# Minimum landmark visibility for upper-body joints (shoulders, arms, head)
# Range: 0.0 - 1.0 (higher = stricter, fewer but more reliable landmarks)
# Default: 0.5
SKISENSE_POSE_VISIBILITY_THRESHOLD=0.5

# Minimum landmark visibility for leg joints (hip, knee, ankle, foot)
# Looser by default because ski postures heavily occlude the inside leg.
# Range: 0.0 - 1.0
# Default: 0.3
SKISENSE_POSE_VISIBILITY_THRESHOLD_LEGS=0.3

# ROI padding ratio: expand bounding box before pose estimation
# Range: 0.0 - 1.0 (0.3 = 30% expansion on each side)
# Default: 0.3
SKISENSE_ROI_PADDING=0.3

# Apply CLAHE (adaptive histogram equalization) to the ROI before pose estimation.
# Can help on low-contrast scenes, but often amplifies snow noise and hurts
# MediaPipe accuracy on our footage. Keep disabled unless validated for your data.
# Options: true, false
# Default: false
SKISENSE_CLAHE_ENABLED=false

# Flip Test-Time Augmentation: run pose estimation on the horizontally flipped ROI
# as well, unflip the landmarks, and keep the ones with higher visibility per joint.
# Doubles inference time but typically recovers landmarks on heavily occluded limbs.
# Options: true, false
# Default: false
SKISENSE_FLIP_TTA_ENABLED=false

# =============================================================================
# Model Settings
# =============================================================================

# MediaPipe pose model type
# Options: lite, full, heavy
#   - lite: Fastest, lowest accuracy (~6MB, best for real-time)
#   - full: Balanced speed/accuracy (~30MB)
#   - heavy: Slowest, highest accuracy (~50MB, recommended for ski analysis)
# Default: heavy
# Note: If you change model type, delete models/pose_landmarker.task to force re-download
SKISENSE_POSE_MODEL_TYPE=heavy

# =============================================================================
# Zoom Settings
# =============================================================================

# Enable automatic zoom to keep skier centered
# Options: true, false
# Default: true
SKISENSE_ZOOM_ENABLED=true

# Zoom magnification level
# Range: 1.0 - 5.0 (1.0 = no zoom, higher = more zoomed in)
# Default: 1.2
SKISENSE_ZOOM_SCALE=1.2

# Zoom smoothing factor (Exponential Moving Average)
# Range: 0.0 - 1.0 (lower = smoother, higher = more responsive)
# Default: 0.08
SKISENSE_ZOOM_SMOOTHING=0.08

# Padding multiplier around bounding box
# Range: 0.5 - 5.0 (higher = more space around subject)
# Default: 1.0
SKISENSE_ZOOM_PADDING=1.0

# =============================================================================
# Common Development Configurations
# =============================================================================

# Development mode (show GUI + debug logs):
# SKISENSE_DEBUG=true
# SKISENSE_SHOW_GUI=true

# Production mode (headless, minimal logs):
# SKISENSE_DEBUG=false
# SKISENSE_SHOW_GUI=false

# High confidence mode (fewer false positives):
# SKISENSE_YOLO_CONFIDENCE=0.5
# SKISENSE_POSE_PRESENCE_CONF=0.5

# CPU-only mode (force CPU):
# SKISENSE_DEVICE=cpu
